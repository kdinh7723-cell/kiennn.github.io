<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bố Kiên ios</title>

<style>
body {
    font-family: Arial;
    background: linear-gradient(to bottom, #dfe9f3, #ffffff);
    text-align: center;
    margin: 0;
    animation: fadeIn 1.5s ease;
}

@keyframes fadeIn {
    from {opacity: 0;}
    to {opacity: 1;}
}

.container {
    padding: 20px;
}

.avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    margin-top: 20px;
    border: 3px solid white;
    animation: float 3s infinite ease-in-out;
}

@keyframes float {
    0% {transform: translateY(0);}
    50% {transform: translateY(-10px);}
    100% {transform: translateY(0);}
}

h1 {
    margin: 10px 0;
}

.subtitle {
    color: purple;
    font-weight: bold;
}

.social {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin: 20px 0;
}

.social a {
    text-decoration: none;
    font-size: 24px;
    background: white;
    padding: 15px;
    border-radius: 15px;
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    transition: 0.3s;
}

.social a:hover {
    transform: scale(1.2);
}

.card {
    background: #f5f5f5;
    margin: 15px;
    padding: 20px;
    border-radius: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

.btn {
    background: linear-gradient(to right, #4facfe, #00f2fe);
    color: white;
    padding: 10px 15px;
    border-radius: 10px;
    text-decoration: none;
}

/* nút nhạc */
.music-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: black;
    color: white;
    padding: 12px;
    border-radius: 50%;
    cursor: pointer;
}
</style>

</head>
<body>

<div class="container">

<img class="avatar" src="https://i.imgur.com/2yaf2wb.png">

<h2>Hi, I am</h2>
<h1>Bố Kiên ios 🇻🇳</h1>
<p class="subtitle">Chia sẻ app & game</p>

<div class="social">
    <a href="https://www.facebook.com/share/18ZX6LEz1y/?mibextid=wwXIfr">📘</a>
</div>

<div class="card">
    <span>Facebook cá nhân</span>
    <a class="btn" href="https://www.facebook.com/share/18ZX6LEz1y/?mibextid=wwXIfr">Mở</a>
</div>

<h2>Tải App / Game</h2>

<div class="card">
    <span>Kho App VIP</span>
    <a class="btn" href="#">⬇</a>
</div>

<div class="card">
    <span>Game Mod</span>
    <a class="btn" href="#">⬇</a>
</div>

</div>

<!-- NHẠC -->
<audio id="music" loop>
    <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<div class="music-btn" onclick="toggleMusic()">🎵</div>

<script>
let isPlaying = false;
function toggleMusic(){
    let music = document.getElementById("music");
    if(isPlaying){
        music.pause();
    } else {
        music.play();
    }
    isPlaying = !isPlaying;
}
</script>

</body>
</html>
